# Gemini (필수)
# GEMINI_API_KEY=your_gemini_api_key

# Chroma Cloud (벡터 검색 — 세 값 모두 있으면 Cloud HTTP 사용)
# CHROMA_API_KEY=your_chroma_cloud_api_key
# CHROMA_TENANT=your_tenant_id
# CHROMA_DATABASE=Portfolio2026

# 컬렉션 이름 분리 (미설정 시: 로컬 dev → portfolio_content_local, Vercel Preview → portfolio_content_preview, 프로덕션 → portfolio_content)
# CHROMA_COLLECTION=portfolio_content_staging

# 벡터 스토어 강제 모드: file | chroma (미설정 시 자동)
# - 로컬 next dev + Chroma Cloud 미설정 → 자동으로 data/embeddings.json 사용 (Chroma 서버 불필요, 프로덕션 DB와 무관)
# VECTOR_STORE_MODE=file
# 로컬에서 Chroma 서버(docker 등)를 쓰려면: CHROMA_USE_LOCAL_SERVER=1 (VECTOR_STORE_MODE 미설정 또는 chroma)

# Chroma 로컬 서버 (SDK 경로 — CHROMA_API_KEY 미설정이고 CHROMA_USE_LOCAL_SERVER=1 일 때)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# Mixpanel (선택 — 미설정 시 코드 내 기본 토큰 사용)
# NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_project_token

# Vercel Blob (로컬 next dev에서는 불필요 — 이미지는 public/uploads 에 저장됨. Vercel 배포+토큰 있을 때만 Blob 사용)
# BLOB_READ_WRITE_TOKEN=
