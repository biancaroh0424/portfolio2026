# Gemini (필수)
# GEMINI_API_KEY=your_gemini_api_key

# Chroma Cloud (벡터 검색 — 설정 시 CloudClient 사용, 미설정 시 로컬 서버 또는 JSON 폴백)
# CHROMA_API_KEY=your_chroma_cloud_api_key
# CHROMA_TENANT=your_tenant_id
# CHROMA_DATABASE=Portfolio2026

# Chroma 로컬 서버 (CHROMA_API_KEY 미설정 시에만 사용)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
